[
  {"id":"L1-01","type":"truth","level":1,"text":"你第一次觉得我有点不一样，是什么时候？","tags":["心动","第一印象"],"mood":["害羞","暧昧"],"relationship":["初识"]},
  {"id":"L1-02","type":"truth","level":1,"text":"你有没有过想找我但又把消息删掉的瞬间？当时想说什么？","tags":["偷偷关注","想靠近"],"mood":["害羞"],"relationship":["初识","熟悉"]},
  {"id":"L1-03","type":"truth","level":1,"text":"如果给我们现在的关系统一取个名字，你会叫什么？","tags":["第一印象","情感坦白"],"mood":["暧昧"],"relationship":["初识","熟悉"]},
  {"id":"L1-04","type":"truth","level":1,"text":"你偷看过我的社交媒体吗？看到什么让你印象深刻的？","tags":["偷偷关注"],"mood":["挑逗","害羞"],"relationship":["初识"]},
  {"id":"L1-05","type":"truth","level":1,"text":"我第一次出现在你面前时，你脑子里冒出来的第一个词是什么？","tags":["第一印象","心动"],"mood":["害羞","暧昧"],"relationship":["初识"]},
  {"id":"L1-06","type":"truth","level":1,"text":"你看我朋友圈的时候，有没有哪条让你多想了一会儿？哪条？","tags":["偷偷关注"],"mood":["挑逗"],"relationship":["初识","熟悉"]},
  {"id":"L1-07","type":"truth","level":1,"text":"如果用一种天气形容我，你会选什么？为什么？","tags":["心动","第一印象"],"mood":["暧昧","温柔"],"relationship":["初识","熟悉"]},
  {"id":"L1-08","type":"truth","level":1,"text":"你觉得我身上哪一点最吸引你？不许说'都挺好'。","tags":["心动","情感坦白"],"mood":["害羞","暧昧"],"relationship":["初识","熟悉"]},
  {"id":"L1-09","type":"truth","level":1,"text":"你会在什么时候突然想起我？最近一次是什么时候？","tags":["偷偷关注","心动"],"mood":["暧昧"],"relationship":["熟悉"]},
  {"id":"L1-10","type":"truth","level":1,"text":"如果明天就见不到我了，你今天最想跟我说的一句话是什么？","tags":["情感坦白","想靠近"],"mood":["紧张","温柔"],"relationship":["熟悉"]},
  {"id":"L1-11","type":"dare","level":1,"text":"拉起我的手，在我手心画一个圈圈，然后告诉我你许了什么愿。","tags":["轻微互动"],"mood":["暧昧","害羞"],"relationship":["初识","熟悉"]},
  {"id":"L1-12","type":"dare","level":1,"text":"和我对视十秒，不许笑，不许躲。如果笑了就加一轮。","tags":["轻微互动"],"mood":["紧张","暧昧"],"relationship":["初识","熟悉"]},
  {"id":"L1-13","type":"dare","level":1,"text":"在我耳边用气声说'我想听你说点什么'——然后等我说。","tags":["轻微互动"],"mood":["挑逗"],"relationship":["熟悉"]},
  {"id":"L1-14","type":"dare","level":1,"text":"用手指轻轻碰一下我的锁骨（可以隔着衣服），然后评价触感。","tags":["轻微互动"],"mood":["暧昧","害羞"],"relationship":["熟悉"]},
  {"id":"L1-15","type":"dare","level":1,"text":"把头发撩到一边露出脖颈，看着我说'这里很敏感，你知道吗'。","tags":["轻微互动"],"mood":["挑逗","大胆"],"relationship":["熟悉"]},
  {"id":"L1-16","type":"dare","level":1,"text":"在我手背上用嘴唇碰一下，停留三秒，不许闭眼。","tags":["轻微互动"],"mood":["暧昧","紧张"],"relationship":["熟悉"]},
  {"id":"L1-17","type":"dare","level":1,"text":"模仿你第一次见到心仪对象时做的第一个动作——对我做一遍。","tags":["轻微互动"],"mood":["挑逗","害羞"],"relationship":["初识","熟悉"]},
  {"id":"L1-18","type":"dare","level":1,"text":"从你手机里翻出一张你偷拍我的照片。如果没有，就现在拍一张。","tags":["偷偷关注","轻微互动"],"mood":["挑逗","大胆"],"relationship":["熟悉"]},
  {"id":"L1-19","type":"dare","level":1,"text":"靠近我，闻一下我的头发或衣领，然后说你现在脑子里在想什么。","tags":["轻微互动","想靠近"],"mood":["暧昧"],"relationship":["熟悉"]},
  {"id":"L1-20","type":"dare","level":1,"text":"用手指绕着我的一绺头发，绕三圈，每圈说一个我的优点。","tags":["轻微互动","心动"],"mood":["暧昧","温柔"],"relationship":["熟悉"]}
]
