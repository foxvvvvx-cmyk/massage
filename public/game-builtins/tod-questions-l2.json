[
  {"id":"L2-01","type":"truth","level":2,"text":"你对我的感觉，有没有超过普通朋友？从什么时候开始的？","tags":["情感坦白"],"mood":["紧张","害羞"],"relationship":["熟悉"]},
  {"id":"L2-02","type":"truth","level":2,"text":"如果我说我吃醋了，你会怎么哄我？不许说'你不会吃醋的'。","tags":["占有欲","吃醋"],"mood":["挑逗"],"relationship":["熟悉","亲密"]},
  {"id":"L2-03","type":"truth","level":2,"text":"你更喜欢我主动还是你主动？说真的，别讲场面话。","tags":["喜欢被怎样对待"],"mood":["挑逗","大胆"],"relationship":["熟悉","亲密"]},
  {"id":"L2-04","type":"truth","level":2,"text":"你想要的'我们'是什么样子的？不用美化，想到什么说什么。","tags":["理想关系","情感坦白"],"mood":["温柔","紧张"],"relationship":["熟悉","亲密"]},
  {"id":"L2-05","type":"truth","level":2,"text":"你有没有因为我跟别人多说了几句话就不爽过？说一次。","tags":["占有欲","吃醋"],"mood":["紧张","挑逗"],"relationship":["熟悉","亲密"]},
  {"id":"L2-06","type":"truth","level":2,"text":"你觉得我在什么时候最让你心动？描述那个瞬间。","tags":["心动","情感坦白"],"mood":["暧昧","温柔"],"relationship":["熟悉","亲密"]},
  {"id":"L2-07","type":"truth","level":2,"text":"如果给你一次机会问我一个问题而你必须诚实回答，你会问什么？","tags":["情感坦白","隐藏想法"],"mood":["紧张","大胆"],"relationship":["熟悉","亲密"]},
  {"id":"L2-08","type":"truth","level":2,"text":"你希望我用什么样的语气叫你？温柔一点还是带点命令？","tags":["喜欢被怎样对待"],"mood":["挑逗","害羞"],"relationship":["熟悉","亲密"]},
  {"id":"L2-09","type":"truth","level":2,"text":"如果我突然三天不找你，你第一天会做什么？第三天呢？","tags":["占有欲","吃醋"],"mood":["紧张"],"relationship":["熟悉","亲密"]},
  {"id":"L2-10","type":"truth","level":2,"text":"你在什么时候会觉得'这个人就是我的'？","tags":["占有欲","理想关系"],"mood":["大胆","温柔"],"relationship":["亲密"]},
  {"id":"L2-11","type":"dare","level":2,"text":"从身后抱住我，头靠在我肩上，说一句你现在最想说的话。","tags":["角色互动"],"mood":["暧昧","温柔"],"relationship":["熟悉","亲密"]},
  {"id":"L2-12","type":"dare","level":2,"text":"用你的方式让我心跳加速，限时30秒。不许直接碰敏感区。","tags":["角色互动","轻微互动"],"mood":["挑逗","大胆"],"relationship":["熟悉","亲密"]},
  {"id":"L2-13","type":"dare","level":2,"text":"咬住我的衣领保持五秒，看着我。不许笑。","tags":["角色互动"],"mood":["挑逗","紧张"],"relationship":["熟悉","亲密"]},
  {"id":"L2-14","type":"dare","level":2,"text":"在我身上选一个地方亲吻，嘴唇以外，至少停留三秒。然后评价一下。","tags":["角色互动"],"mood":["暧昧","大胆"],"relationship":["熟悉","亲密"]},
  {"id":"L2-15","type":"dare","level":2,"text":"用你最撩的声线念'你再这样我就把你带回家了'——对着我说，别对着空气。","tags":["角色互动"],"mood":["挑逗","大胆"],"relationship":["熟悉","亲密"]},
  {"id":"L2-16","type":"dare","level":2,"text":"让我闭上眼睛。你用一根手指碰我身体任何一个地方。只能一下。让我猜你碰了哪。","tags":["角色互动","信任"],"mood":["紧张","暧昧"],"relationship":["熟悉","亲密"]},
  {"id":"L2-17","type":"dare","level":2,"text":"向我描述你理想中的一个吻——在哪里、什么姿势、你怎么开始。","tags":["理想关系","情感坦白"],"mood":["挑逗","大胆"],"relationship":["亲密"]},
  {"id":"L2-18","type":"dare","level":2,"text":"用你的手指沿着我手臂慢慢滑到手腕，告诉我你在想什么。不许说'没什么'。","tags":["角色互动","情感坦白"],"mood":["暧昧","紧张"],"relationship":["熟悉","亲密"]},
  {"id":"L2-19","type":"dare","level":2,"text":"向我说'你是我的'——然后用你的方式让它听起来像真的，不是台词。","tags":["占有欲","角色互动"],"mood":["大胆","温柔"],"relationship":["亲密"]},
  {"id":"L2-20","type":"dare","level":2,"text":"打开手机相册，给我看最近保存的一张图（不许提前删），解释为什么存它。","tags":["情感坦白","信任"],"mood":["紧张","害羞"],"relationship":["熟悉","亲密"]}
]
