[
  {"id":"L3-01","type":"truth","level":3,"text":"你最怕我问你什么？现在我问了——你答吗？","tags":["隐藏想法","信任挑战"],"mood":["紧张","大胆"],"relationship":["亲密"]},
  {"id":"L3-02","type":"truth","level":3,"text":"你上次因为我哭是什么时候？为什么？","tags":["情绪暴露"],"mood":["温柔","害羞"],"relationship":["亲密"]},
  {"id":"L3-03","type":"truth","level":3,"text":"你现在脑子里最想对我做的一件事是什么？用一句话说。不用修饰。","tags":["隐藏想法","情绪暴露"],"mood":["大胆","挑逗"],"relationship":["亲密"]},
  {"id":"L3-04","type":"truth","level":3,"text":"你有没有过怕我离开的瞬间？那一刻你做了什么？","tags":["情绪暴露","隐藏想法"],"mood":["紧张","温柔"],"relationship":["亲密"]},
  {"id":"L3-05","type":"truth","level":3,"text":"你最想让我知道但一直不敢说的一件事是什么？","tags":["隐藏想法","信任挑战"],"mood":["紧张","害羞"],"relationship":["亲密"]},
  {"id":"L3-06","type":"truth","level":3,"text":"你觉得我们之间最脆弱的部分是什么？","tags":["情绪暴露","理想关系"],"mood":["温柔","紧张"],"relationship":["亲密"]},
  {"id":"L3-07","type":"truth","level":3,"text":"如果今天是最后一次见我，你最想让我记住你什么？","tags":["情绪暴露","隐藏想法"],"mood":["温柔","紧张"],"relationship":["亲密"]},
  {"id":"L3-08","type":"truth","level":3,"text":"你什么时候最想我？不要敷衍，说一个具体的瞬间。","tags":["心动","情感坦白"],"mood":["害羞","温柔"],"relationship":["亲密"]},
  {"id":"L3-09","type":"dare","level":3,"text":"闭上眼睛。接下来30秒，我来引导你做一件事。不许偷看。你信我吗？","tags":["信任挑战","高亲密互动"],"mood":["紧张","大胆"],"relationship":["亲密"]},
  {"id":"L3-10","type":"dare","level":3,"text":"现在你是老师/主人/police——你选一个角色。我是你指定的角色。三句话，开始演。","tags":["角色扮演","高亲密互动"],"mood":["挑逗","大胆"],"relationship":["亲密"]},
  {"id":"L3-11","type":"dare","level":3,"text":"让我向你提一个要求。你必须在3秒内开始执行。不可以是'让我也提一个'。","tags":["信任挑战","高亲密互动"],"mood":["紧张","大胆"],"relationship":["亲密"]},
  {"id":"L3-12","type":"dare","level":3,"text":"用你最低最慢的声线，向我描述一个你幻想的场景的前30秒。不许省略细节。","tags":["角色扮演","情绪暴露"],"mood":["挑逗","紧张"],"relationship":["亲密"]},
  {"id":"L3-13","type":"dare","level":3,"text":"坐在我对面，看着我。说出你最喜欢我的三个地方。每说一个，指那个位置。","tags":["情感坦白","高亲密互动"],"mood":["温柔","害羞"],"relationship":["亲密"]},
  {"id":"L3-14","type":"dare","level":3,"text":"把你手机解锁给我。我只翻30秒。你看着我的表情，不许抢回去。","tags":["信任挑战"],"mood":["紧张","大胆"],"relationship":["亲密"]},
  {"id":"L3-15","type":"dare","level":3,"text":"和我在角色扮演里对戏一分钟——你演某个身份的人，三句话之内让我猜出你演的是谁。","tags":["角色扮演","高亲密互动"],"mood":["挑逗","大胆"],"relationship":["亲密"]},
  {"id":"L3-16","type":"dare","level":3,"text":"向我坦白一个你从未告诉过任何人的秘密。不用长。说完之后，我不许追问。","tags":["信任挑战","情绪暴露"],"mood":["紧张","温柔"],"relationship":["亲密"]}
]
